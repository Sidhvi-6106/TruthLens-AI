FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-another-random-string
# Local demo is fine with SQLite. For deployment, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///truthlens_dev.db
REDIS_URL=redis://localhost:6379/0
UPLOAD_FOLDER=uploads

# News Provider API Keys (optional - rich demo data used when absent)
NEWS_API_KEY=
GNEWS_API_KEY=
MEDIASTACK_API_KEY=
GUARDIAN_API_KEY=
NYTIMES_API_KEY=

# AI Service API Keys (optional - intelligent simulation used when absent)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
GROQ_API_KEY=

# OAuth (optional - email auth always available)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Mail (optional - OTP printed to console when absent)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
